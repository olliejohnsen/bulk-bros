// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model BulkCard {
  id        String   @id @default(cuid())
  imageUrl  String
  username  String
  likes     Int      @default(0)
  cardName  String?
  setName   String?
  /** Card print language: en, ja, ko, zh (null = legacy/unknown) */
  language  String?
  createdAt DateTime @default(now())
}
